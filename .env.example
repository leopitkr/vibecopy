# VibeCopy — copy to .env.local and fill with real values. Never commit .env.local.

# --- Public (NEXT_PUBLIC_* = exposed to browser; no secrets) ---
NEXT_PUBLIC_APP_URL=https://localhost:3000

# --- Supabase (server + client: anon key is safe for client; RLS protects data) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Direct Postgres (server-only: migrations, server-side DB access)
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres
# Optional: server-only, bypasses RLS; use only in trusted server code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Server-only (never expose to client) ---
OPENAI_API_KEY=sk-your-openai-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
