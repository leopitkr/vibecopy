# VibeCopy — copy to .env.local and fill with real values. Never commit .env.local.

# --- Public (NEXT_PUBLIC_* = exposed to browser; no secrets here) ---
NEXT_PUBLIC_APP_URL=https://localhost:3000

# --- Server-only (never use in client code) ---
OPENAI_API_KEY=sk-your-openai-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# --- Server + client (Supabase anon key is safe for client; RLS protects data) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
