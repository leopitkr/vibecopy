# VibeCopy — copy from this file to .env.local and fill with real values.
# Never commit .env.local or any file with secrets.

# Public (exposed to browser). Phase 0+.
NEXT_PUBLIC_APP_URL=https://localhost:3000

# Supabase. Phase 1 (auth, DB).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# OpenAI. Phase 2 (generate).
OPENAI_API_KEY=sk-your-openai-key

# Stripe. Phase 3 (payments).
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
